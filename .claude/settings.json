{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash.*git push.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/pre-push-gate.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git status --porcelain | grep -q . && echo '[cradle-coach] Uncommitted changes. Consider /review before stopping.' || true"
          }
        ]
      }
    ]
  }
}
